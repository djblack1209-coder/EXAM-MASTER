{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "../dist",
    "rootDir": "..",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "@lafjs/cloud": ["./cloud-shim.js"]
    }
  },
  "include": ["./**/*.ts", "../functions/**/*.ts"],
  "exclude": ["../node_modules"]
}
