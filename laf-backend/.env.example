# ============================================
# Exam-Master 后端环境变量配置示例
# ✅ B017: 环境变量文档化（完整版）
# 
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入真实的配置值
# 3. 确保 .env 文件已加入 .gitignore
# ============================================

# ---------- 运行环境 ----------
# 可选值: development, production
NODE_ENV=development

# 日志级别: info, warn, error
LOG_LEVEL=info

# ---------- 微信小程序 ----------
# 微信小程序 AppID（从微信公众平台获取）
WX_APPID=your_wx_appid_here
# 微信小程序 AppSecret（从微信公众平台获取）
WX_SECRET_PLACEHOLDER

# ---------- 微信公众号（H5 OAuth 登录） ----------
# 微信公众号 AppID
WX_GZH_APPID=your_wx_gzh_appid_here
# 微信公众号 AppSecret
SECRET_PLACEHOLDER

# ---------- QQ 登录 ----------
# QQ 互联 AppID
QQ_APPID=your_qq_appid_here
# QQ 互联 AppSecret
SECRET_PLACEHOLDER
# QQ OAuth 回调地址
QQ_REDIRECT_URI=https://your-domain.com/qq-callback

# ---------- JWT 认证 ----------
# JWT 签名密钥（建议使用 64 位以上随机字符串）
# 生成方式: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET_PLACEHOLDER

# ---------- 密码安全 ----------
# 密码哈希盐值（建议使用 32 位以上随机字符串）
PASSWORD_SALT=your_password_salt_here

# ---------- AI 服务（智谱） ----------
# 智谱 AI API Key（从 open.bigmodel.cn 获取）
AI_PROVIDER_KEY_PLACEHOLDER

# ---------- AI 免费号池（6个免费供应商） ----------
# Groq (llama-3.3-70b-versatile, 14500 req/day)
API_KEY_PLACEHOLDER
# Google Gemini (gemini-2.0-flash-exp, 1500 req/day)
API_KEY_PLACEHOLDER
# OpenRouter (gemini-2.0-flash-exp:free, 200 req/day)
API_KEY_PLACEHOLDER
# Cerebras (llama-3.3-70b, 30 req/min)
API_KEY_PLACEHOLDER
# Mistral (mistral-small-latest, 免费层)
API_KEY_PLACEHOLDER
# Manus (gpt-4o-mini, 免费层)
API_KEY_PLACEHOLDER

# ---------- AI 多Agent课堂配置 ----------
# 各Agent角色默认使用的模型
DEFAULT_TEACHER_MODEL=glm-4-plus
DEFAULT_STUDENT_MODEL=glm-4-flash
DEFAULT_EXAMINER_MODEL=glm-4.5-air
# LangSmith 追踪（可选，用于调试多Agent编排）
API_KEY_PLACEHOLDER
# SiliconFlow API Keys（支持多 Key 负载均衡）
SILICONFLOW_API_KEY_1=your_siliconflow_key_1_here
SILICONFLOW_API_KEY_2=your_siliconflow_key_2_here
SILICONFLOW_API_KEY_3=your_siliconflow_key_3_here

# ---------- AI 路由配置 ----------
# 是否启用自动切换（当某个 provider 不可用时自动切换）
AI_ROUTER_ENABLE_AUTO_SWITCH=true
# 是否启用负载均衡
AI_ROUTER_ENABLE_LOAD_BALANCE=true
# 健康检查间隔（毫秒）
AI_ROUTER_HEALTH_CHECK_INTERVAL=300000
# 最大重试次数
AI_ROUTER_MAX_RETRIES=2
# AI 请求超时（毫秒）
AI_ROUTER_TIMEOUT=30000
# 是否优先使用免费模型
AI_ROUTER_PREFER_FREE_MODELS=true
# 每日预算限制（元）
AI_ROUTER_DAILY_BUDGET_LIMIT=10
# 各 Provider 流量比例
AI_ROUTER_SILICONFLOW_RATIO=0.6
AI_ROUTER_ZHIPU_RATIO=0.3
AI_ROUTER_TENCENT_RATIO=0.1

# ---------- 腾讯云服务 ----------
# 腾讯云 SecretId（用于证件照、COS 等服务）
TENCENT_SECRET_ID=your_tencent_secret_id_here
# 腾讯云 SecretKey
TENCENT_SECRET_KEY=your_tencent_secret_key_here
# 腾讯云 AppID
TENCENT_APPID=your_tencent_appid_here
# COS 存储桶名称
TENCENT_COS_BUCKET=your-bucket-name
# COS 区域
TENCENT_COS_REGION=ap-beijing

# ---------- 文档转换 ----------
# CloudConvert API Key（用于 PDF/Word 转换）
API_KEY_PLACEHOLDER

# ---------- 搜索服务 ----------
# SerpApi Key（用于搜索功能）
API_KEY_PLACEHOLDER
# Brave Search API Key
API_KEY_PLACEHOLDER

# ---------- 邮件服务（SMTP） ----------
# SMTP 服务器地址
SMTP_HOST=smtp.example.com
# SMTP 端口
SMTP_PORT=465
# SMTP 用户名
SMTP_USER=your_email@example.com
# SMTP 密码/授权码
SMTP_PASS=your_smtp_password_here
# 发件人地址
SMTP_FROM=noreply@exammaster.app

# ---------- GitHub ----------
# GitHub Personal Access Token（用于版本检查等）
TOKEN_PLACEHOLDER

# ---------- 管理员 ----------
# 管理员操作密钥（用于数据清理等敏感操作）
SECRET_PLACEHOLDER
# 数据清理授权密钥
SECRET_PLACEHOLDER
# 账户彻底清除授权密钥（account-purge）
TOKEN_PLACEHOLDER

# ---------- 安全配置 ----------
# CORS 允许的源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com
# 服务间通信 API Key
API_KEY_PLACEHOLDER
# Job Bot 接管通知专用令牌（优先于 INTERNAL_API_KEY）
TOKEN_PLACEHOLDER
# Job Bot 接管通知默认接收邮箱（可不填，默认回落 SMTP_USER）
JOB_BOT_HANDOFF_RECEIVER=your_real_email@example.com
# Job Bot 接管通知频控：窗口内最大请求数
JOB_BOT_HANDOFF_RATE_LIMIT=20
# Job Bot 接管通知频控窗口（毫秒）
JOB_BOT_HANDOFF_RATE_WINDOW_MS=60000
# Job Bot 接管通知去重窗口（毫秒）
JOB_BOT_HANDOFF_DEDUPE_WINDOW_MS=120000
# 审核模式（微信审核期间开启）
AUDIT_MODE=false

# ---------- 速率限制 ----------
# 速率限制窗口（毫秒）
RATE_LIMIT_WINDOW_MS=60000
# 窗口内最大请求数
RATE_LIMIT_MAX_REQUESTS=100

# ---------- 缓存配置 ----------
# 是否启用缓存
CACHE_ENABLED=true
# 缓存过期时间（秒）
CACHE_TTL=300

# ---------- 脚本与测试 ----------
# 后端压测/联调 API 地址（scripts/test/load-test.ts 使用）
LAF_API_URL=https://your-sealos-domain.sealosbja.site
