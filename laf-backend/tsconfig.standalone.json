{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "noEmitOnError": false
  },
  "include": ["standalone/**/*.ts", "functions/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
