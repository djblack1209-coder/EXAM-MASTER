{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mistake_book",
  "description": "错题本集合 - 存储用户的错题记录",
  "type": "object",
  "required": ["user_id", "question_content", "user_answer", "correct_answer"],
  "properties": {
    "_id": {
      "type": "string",
      "description": "MongoDB ObjectId"
    },
    "user_id": {
      "type": "string",
      "description": "用户ID"
    },
    "question_id": {
      "type": ["string", "null"],
      "description": "关联题目ID（如果来自题库）"
    },
    "question_content": {
      "type": "string",
      "description": "题目内容",
      "minLength": 1
    },
    "options": {
      "type": "array",
      "description": "选项列表",
      "items": { "type": "string" },
      "default": []
    },
    "user_answer": {
      "type": "string",
      "description": "用户答案"
    },
    "correct_answer": {
      "type": "string",
      "description": "正确答案"
    },
    "analysis": {
      "type": "string",
      "description": "答案解析",
      "default": ""
    },
    "category": {
      "type": "string",
      "description": "科目分类",
      "default": "综合"
    },
    "tags": {
      "type": "array",
      "description": "标签列表（知识点、错误类型等）",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "value": { "type": "string" },
          "label": { "type": "string" }
        }
      },
      "default": []
    },
    "error_type": {
      "type": "string",
      "description": "错误类型",
      "enum": ["concept_confusion", "calculation_error", "memory_lapse", "logic_error", "careless_mistake", "knowledge_gap"],
      "default": "knowledge_gap"
    },
    "difficulty": {
      "type": "string",
      "description": "难度等级",
      "enum": ["easy", "medium", "hard"],
      "default": "medium"
    },
    "wrong_count": {
      "type": "integer",
      "description": "错误次数",
      "default": 1,
      "minimum": 1
    },
    "review_count": {
      "type": "integer",
      "description": "复习次数",
      "default": 0,
      "minimum": 0
    },
    "is_mastered": {
      "type": "boolean",
      "description": "是否已掌握",
      "default": false
    },
    "last_review_time": {
      "type": ["integer", "null"],
      "description": "最后复习时间戳"
    },
    "next_review_time": {
      "type": ["integer", "null"],
      "description": "下次复习时间戳（SM-2算法计算）"
    },
    "ease_factor": {
      "type": "number",
      "description": "SM-2算法难度因子",
      "default": 2.5,
      "minimum": 1.3
    },
    "interval_days": {
      "type": "integer",
      "description": "SM-2算法复习间隔天数",
      "default": 1,
      "minimum": 1
    },
    "created_at": {
      "type": "integer",
      "description": "创建时间戳"
    },
    "updated_at": {
      "type": "integer",
      "description": "更新时间戳"
    }
  },
  "indexes": [
    { "key": { "user_id": 1, "created_at": -1 }, "name": "idx_user_created" },
    { "key": { "user_id": 1, "is_mastered": 1 }, "name": "idx_user_mastered" },
    { "key": { "user_id": 1, "category": 1 }, "name": "idx_user_category" },
    { "key": { "user_id": 1, "next_review_time": 1 }, "name": "idx_user_review" },
    { "key": { "user_id": 1, "question_id": 1 }, "unique": true, "sparse": true, "name": "idx_user_question" }
  ],
  "examples": [
    {
      "_id": "m_001",
      "user_id": "user_001",
      "question_id": "q_001",
      "question_content": "马克思主义哲学的直接理论来源是？",
      "options": ["A. 德国古典哲学", "B. 英国古典政治经济学", "C. 法国空想社会主义", "D. 古希腊哲学"],
      "user_answer": "B",
      "correct_answer": "A",
      "analysis": "马克思主义哲学的直接理论来源是德国古典哲学。",
      "category": "政治",
      "tags": [
        { "type": "knowledge", "value": "马克思主义", "label": "马克思主义" },
        { "type": "error", "value": "concept_confusion", "label": "概念混淆" }
      ],
      "error_type": "concept_confusion",
      "difficulty": "medium",
      "wrong_count": 2,
      "review_count": 1,
      "is_mastered": false,
      "last_review_time": 1737878400000,
      "next_review_time": 1738051200000,
      "ease_factor": 2.3,
      "interval_days": 2,
      "created_at": 1737792000000,
      "updated_at": 1737878400000
    }
  ]
}
