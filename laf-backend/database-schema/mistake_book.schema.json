{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mistake_book",
  "description": "错题本集合 - 存储用户的错题记录 (v2.0增强版)",
  "type": "object",
  "required": ["user_id", "question_content", "user_answer", "correct_answer"],
  "properties": {
    "_id": {
      "type": "string",
      "description": "MongoDB ObjectId"
    },
    "user_id": {
      "type": "string",
      "description": "用户ID",
      "minLength": 1,
      "maxLength": 64
    },
    "question_id": {
      "type": ["string", "null"],
      "description": "关联题目ID（如果来自题库）",
      "maxLength": 64
    },
    "question_content": {
      "type": "string",
      "description": "题目内容",
      "minLength": 1,
      "maxLength": 5000
    },
    "options": {
      "type": "array",
      "description": "选项列表",
      "items": { "type": "string", "maxLength": 1000 },
      "default": [],
      "maxItems": 10
    },
    "user_answer": {
      "type": "string",
      "description": "用户答案",
      "maxLength": 100
    },
    "correct_answer": {
      "type": "string",
      "description": "正确答案",
      "maxLength": 100
    },
    "analysis": {
      "type": "string",
      "description": "答案解析",
      "default": "",
      "maxLength": 10000
    },
    "category": {
      "type": "string",
      "description": "科目分类",
      "enum": ["政治", "英语", "数学", "专业课", "综合"],
      "default": "综合"
    },
    "sub_category": {
      "type": ["string", "null"],
      "description": "子分类（如：马原、毛中特、阅读理解等）",
      "maxLength": 50
    },
    "tags": {
      "type": "array",
      "description": "标签列表（支持字符串或对象格式）",
      "items": {
        "oneOf": [
          { "type": "string", "maxLength": 50 },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "maxLength": 20 },
              "value": { "type": "string", "maxLength": 50 },
              "label": { "type": "string", "maxLength": 50 }
            }
          }
        ]
      },
      "default": [],
      "maxItems": 20
    },
    "error_type": {
      "type": "string",
      "description": "错误类型",
      "enum": ["concept_confusion", "calculation_error", "memory_lapse", "logic_error", "careless_mistake", "knowledge_gap", "time_pressure", "unknown"],
      "default": "knowledge_gap"
    },
    "difficulty": {
      "type": "string",
      "description": "难度等级",
      "enum": ["easy", "medium", "hard"],
      "default": "medium"
    },
    "wrong_count": {
      "type": "integer",
      "description": "错误次数",
      "default": 1,
      "minimum": 1,
      "maximum": 1000
    },
    "review_count": {
      "type": "integer",
      "description": "复习次数",
      "default": 0,
      "minimum": 0,
      "maximum": 10000
    },
    "correct_streak": {
      "type": "integer",
      "description": "连续答对次数（用于判断掌握程度）",
      "default": 0,
      "minimum": 0
    },
    "is_mastered": {
      "type": "boolean",
      "description": "是否已掌握",
      "default": false
    },
    "mastered_at": {
      "type": ["integer", "null"],
      "description": "掌握时间戳"
    },
    "last_review_time": {
      "type": ["integer", "null"],
      "description": "最后复习时间戳"
    },
    "next_review_time": {
      "type": ["integer", "null"],
      "description": "下次复习时间戳（SM-2算法计算）"
    },
    "ease_factor": {
      "type": "number",
      "description": "SM-2算法难度因子",
      "default": 2.5,
      "minimum": 1.3,
      "maximum": 5.0
    },
    "interval_days": {
      "type": "integer",
      "description": "SM-2算法复习间隔天数",
      "default": 1,
      "minimum": 1,
      "maximum": 365
    },
    "source": {
      "type": ["string", "null"],
      "description": "题目来源（如：2024真题、AI生成、手动添加）",
      "maxLength": 100
    },
    "notes": {
      "type": ["string", "null"],
      "description": "用户笔记",
      "maxLength": 2000
    },
    "created_at": {
      "type": "integer",
      "description": "创建时间戳"
    },
    "updated_at": {
      "type": "integer",
      "description": "更新时间戳"
    }
  },
  "indexes": [
    { "key": { "user_id": 1, "created_at": -1 }, "name": "idx_user_created" },
    { "key": { "user_id": 1, "is_mastered": 1 }, "name": "idx_user_mastered" },
    { "key": { "user_id": 1, "category": 1 }, "name": "idx_user_category" },
    { "key": { "user_id": 1, "sub_category": 1 }, "sparse": true, "name": "idx_user_subcategory" },
    { "key": { "user_id": 1, "next_review_time": 1 }, "name": "idx_user_review" },
    { "key": { "user_id": 1, "question_id": 1 }, "unique": true, "sparse": true, "name": "idx_user_question" },
    { "key": { "user_id": 1, "error_type": 1 }, "name": "idx_user_error_type" },
    { "key": { "user_id": 1, "difficulty": 1 }, "name": "idx_user_difficulty" },
    { "key": { "user_id": 1, "tags": 1 }, "name": "idx_user_tags" },
    { "key": { "user_id": 1, "wrong_count": -1 }, "name": "idx_user_wrong_count" }
  ],
  "examples": [
    {
      "_id": "m_001",
      "user_id": "user_001",
      "question_id": "q_001",
      "question_content": "马克思主义哲学的直接理论来源是？",
      "options": ["A. 德国古典哲学", "B. 英国古典政治经济学", "C. 法国空想社会主义", "D. 古希腊哲学"],
      "user_answer": "B",
      "correct_answer": "A",
      "analysis": "马克思主义哲学的直接理论来源是德国古典哲学。",
      "category": "政治",
      "sub_category": "马原",
      "tags": ["马克思主义", "哲学来源"],
      "error_type": "concept_confusion",
      "difficulty": "medium",
      "wrong_count": 2,
      "review_count": 1,
      "correct_streak": 0,
      "is_mastered": false,
      "mastered_at": null,
      "last_review_time": 1737878400000,
      "next_review_time": 1738051200000,
      "ease_factor": 2.3,
      "interval_days": 2,
      "source": "2023真题",
      "notes": "注意区分三大来源",
      "created_at": 1737792000000,
      "updated_at": 1737878400000
    }
  ]
}
