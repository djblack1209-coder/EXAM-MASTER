{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "users",
  "description": "用户集合 - 存储用户基本信息和学习统计",
  "type": "object",
  "required": ["openid", "created_at"],
  "properties": {
    "_id": {
      "type": "string",
      "description": "MongoDB ObjectId"
    },
    "openid": {
      "type": "string",
      "description": "微信小程序 openid",
      "minLength": 28,
      "maxLength": 128
    },
    "unionid": {
      "type": ["string", "null"],
      "description": "微信开放平台 unionid（可选）"
    },
    "nickname": {
      "type": "string",
      "description": "用户昵称",
      "default": "考研学子",
      "maxLength": 32
    },
    "avatar_url": {
      "type": "string",
      "description": "头像URL",
      "default": ""
    },
    "phone": {
      "type": ["string", "null"],
      "description": "手机号（可选）"
    },
    "role": {
      "type": "string",
      "enum": ["user", "vip", "admin"],
      "default": "user",
      "description": "用户角色"
    },
    "streak_days": {
      "type": "integer",
      "description": "连续学习天数",
      "default": 0,
      "minimum": 0
    },
    "total_study_days": {
      "type": "integer",
      "description": "累计学习天数",
      "default": 0,
      "minimum": 0
    },
    "total_study_minutes": {
      "type": "integer",
      "description": "累计学习分钟数",
      "default": 0,
      "minimum": 0
    },
    "total_questions": {
      "type": "integer",
      "description": "累计做题数",
      "default": 0,
      "minimum": 0
    },
    "correct_questions": {
      "type": "integer",
      "description": "累计正确题数",
      "default": 0,
      "minimum": 0
    },
    "last_study_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "最后学习日期 (YYYY-MM-DD)"
    },
    "achievements": {
      "type": "array",
      "description": "成就列表",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "unlocked_at": { "type": "integer" }
        }
      },
      "default": []
    },
    "settings": {
      "type": "object",
      "description": "用户设置",
      "properties": {
        "theme": { "type": "string", "enum": ["light", "dark", "auto"], "default": "auto" },
        "notification": { "type": "boolean", "default": true },
        "daily_goal": { "type": "integer", "default": 30, "minimum": 10, "maximum": 200 }
      },
      "default": {}
    },
    "target_school": {
      "type": "object",
      "description": "目标院校信息",
      "properties": {
        "name": { "type": "string" },
        "major": { "type": "string" },
        "exam_date": { "type": "string" }
      }
    },
    "created_at": {
      "type": "integer",
      "description": "创建时间戳"
    },
    "updated_at": {
      "type": "integer",
      "description": "更新时间戳"
    }
  },
  "indexes": [
    { "key": { "openid": 1 }, "unique": true, "name": "idx_openid" },
    { "key": { "unionid": 1 }, "sparse": true, "name": "idx_unionid" },
    { "key": { "created_at": -1 }, "name": "idx_created_at" },
    { "key": { "streak_days": -1 }, "name": "idx_streak_ranking" }
  ],
  "examples": [
    {
      "_id": "user_001",
      "openid": "oXXXX_test_openid_001",
      "nickname": "考研小王",
      "avatar_url": "https://api.dicebear.com/7.x/avataaars/png?seed=user001",
      "role": "user",
      "streak_days": 15,
      "total_study_days": 30,
      "total_study_minutes": 1800,
      "total_questions": 500,
      "correct_questions": 420,
      "last_study_date": "2026-01-25",
      "achievements": [{ "id": "first_login", "name": "初来乍到", "unlocked_at": 1737792000000 }],
      "settings": { "theme": "auto", "notification": true, "daily_goal": 50 },
      "created_at": 1737792000000,
      "updated_at": 1737878400000
    }
  ]
}
