{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "users",
  "description": "用户集合 - 存储用户基本信息和学习统计",
  "type": "object",
  "required": ["created_at"],
  "properties": {
    "_id": {
      "type": "string",
      "description": "MongoDB ObjectId"
    },
    "openid": {
      "type": ["string", "null"],
      "description": "微信小程序 openid（微信登录时必填）",
      "minLength": 28,
      "maxLength": 128
    },
    "unionid": {
      "type": ["string", "null"],
      "description": "微信开放平台 unionid（可选）"
    },
    "email": {
      "type": ["string", "null"],
      "description": "邮箱地址（邮箱登录时必填）",
      "format": "email",
      "maxLength": 128
    },
    "password_hash": {
      "type": ["string", "null"],
      "description": "密码哈希（邮箱登录时使用）",
      "maxLength": 256
    },
    "login_type": {
      "type": "string",
      "description": "注册登录方式",
      "enum": ["wechat", "email", "qq"],
      "default": "wechat"
    },
    "nickname": {
      "type": "string",
      "description": "用户昵称",
      "default": "考研学子",
      "maxLength": 32
    },
    "avatar_url": {
      "type": "string",
      "description": "头像URL",
      "default": ""
    },
    "phone": {
      "type": ["string", "null"],
      "description": "手机号（可选）"
    },
    "role": {
      "type": "string",
      "enum": ["user", "vip", "admin"],
      "default": "user",
      "description": "用户角色"
    },
    "streak_days": {
      "type": "integer",
      "description": "连续学习天数",
      "default": 0,
      "minimum": 0
    },
    "total_study_days": {
      "type": "integer",
      "description": "累计学习天数",
      "default": 0,
      "minimum": 0
    },
    "total_study_minutes": {
      "type": "integer",
      "description": "累计学习分钟数",
      "default": 0,
      "minimum": 0
    },
    "total_questions": {
      "type": "integer",
      "description": "累计做题数",
      "default": 0,
      "minimum": 0
    },
    "correct_questions": {
      "type": "integer",
      "description": "累计正确题数",
      "default": 0,
      "minimum": 0
    },
    "last_study_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "最后学习日期 (YYYY-MM-DD)"
    },
    "achievements": {
      "type": "array",
      "description": "成就列表",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "unlocked_at": { "type": "integer" }
        }
      },
      "default": []
    },
    "settings": {
      "type": "object",
      "description": "用户设置",
      "properties": {
        "theme": { "type": "string", "enum": ["light", "dark", "auto"], "default": "auto" },
        "notification": { "type": "boolean", "default": true },
        "daily_goal": { "type": "integer", "default": 30, "minimum": 10, "maximum": 200 }
      },
      "default": {}
    },
    "target_school": {
      "type": "object",
      "description": "目标院校信息",
      "properties": {
        "name": { "type": "string" },
        "major": { "type": "string" },
        "exam_date": { "type": "string" }
      }
    },
    "practice_config": {
      "type": "object",
      "description": "练习模式配置 (v2.0新增)",
      "properties": {
        "default_mode": { "type": "string", "enum": ["normal", "exam", "review", "challenge"], "default": "normal" },
        "question_count": { "type": "integer", "default": 20, "minimum": 5, "maximum": 100 },
        "time_limit": { "type": "integer", "default": 30, "minimum": 5, "maximum": 180 },
        "show_answer_immediately": { "type": "boolean", "default": true },
        "auto_next": { "type": "boolean", "default": false },
        "shuffle_options": { "type": "boolean", "default": false },
        "difficulty_preference": { "type": "string", "enum": ["easy", "medium", "hard", "adaptive"], "default": "adaptive" },
        "categories": { "type": "array", "items": { "type": "string" }, "default": [] },
        "daily_goal": { "type": "integer", "default": 50, "minimum": 10, "maximum": 500 },
        "reminder_enabled": { "type": "boolean", "default": false },
        "reminder_time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$", "default": "20:00" }
      },
      "default": {}
    },
    "created_at": {
      "type": "integer",
      "description": "创建时间戳（毫秒级 Unix timestamp，如 1737792000000。使用整数而非 Date 类型，便于跨平台序列化和前端直接使用）"
    },
    "updated_at": {
      "type": "integer",
      "description": "更新时间戳（毫秒级 Unix timestamp，每次修改用户信息时更新）"
    }
  },
  "indexes": [
    { "key": { "openid": 1 }, "unique": true, "sparse": true, "name": "idx_openid" },
    { "key": { "unionid": 1 }, "sparse": true, "name": "idx_unionid" },
    { "key": { "email": 1 }, "unique": true, "sparse": true, "name": "idx_email" },
    { "key": { "phone": 1 }, "sparse": true, "name": "idx_phone" },
    { "key": { "login_type": 1 }, "name": "idx_login_type" },
    { "key": { "nickname": 1 }, "name": "idx_nickname" },
    { "key": { "role": 1 }, "name": "idx_role" },
    { "key": { "created_at": -1 }, "name": "idx_created_at" },
    { "key": { "updated_at": -1 }, "name": "idx_updated_at" },
    { "key": { "streak_days": -1 }, "name": "idx_streak_ranking" },
    { "key": { "total_questions": -1 }, "name": "idx_questions_ranking" },
    { "key": { "total_study_minutes": -1 }, "name": "idx_study_time_ranking" },
    { "key": { "last_study_date": -1 }, "name": "idx_last_study" },
    { "key": { "role": 1, "created_at": -1 }, "name": "idx_role_created" }
  ],
  "examples": [
    {
      "_id": "user_001",
      "openid": "oXXXX_test_openid_001",
      "nickname": "考研小王",
      "avatar_url": "https://api.dicebear.com/7.x/avataaars/png?seed=user001",
      "role": "user",
      "streak_days": 15,
      "total_study_days": 30,
      "total_study_minutes": 1800,
      "total_questions": 500,
      "correct_questions": 420,
      "last_study_date": "2026-01-25",
      "achievements": [{ "id": "first_login", "name": "初来乍到", "unlocked_at": 1737792000000 }],
      "settings": { "theme": "auto", "notification": true, "daily_goal": 50 },
      "created_at": 1737792000000,
      "updated_at": 1737878400000
    }
  ]
}
