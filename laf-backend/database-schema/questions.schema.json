{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "questions",
  "description": "题库集合 - 存储所有考研题目",
  "type": "object",
  "required": ["question", "options", "answer", "category"],
  "properties": {
    "_id": {
      "type": "string",
      "description": "MongoDB ObjectId"
    },
    "question": {
      "type": "string",
      "description": "题目内容",
      "minLength": 5,
      "maxLength": 2000
    },
    "options": {
      "type": "array",
      "description": "选项列表",
      "items": { "type": "string" },
      "minItems": 2,
      "maxItems": 8
    },
    "answer": {
      "type": "string",
      "description": "正确答案（单选: A/B/C/D, 多选: AB/ABC等）",
      "pattern": "^[A-H]+$"
    },
    "analysis": {
      "type": "string",
      "description": "答案解析",
      "default": ""
    },
    "category": {
      "type": "string",
      "description": "科目分类",
      "enum": ["政治", "英语", "数学", "专业课", "综合"]
    },
    "sub_category": {
      "type": "string",
      "description": "子分类（如：马原、毛中特、阅读理解等）"
    },
    "type": {
      "type": "string",
      "description": "题型",
      "enum": ["单选", "多选", "判断", "填空", "简答"],
      "default": "单选"
    },
    "difficulty": {
      "type": "string",
      "description": "难度等级",
      "enum": ["easy", "medium", "hard"],
      "default": "medium"
    },
    "knowledge_points": {
      "type": "array",
      "description": "关联知识点",
      "items": { "type": "string" },
      "default": []
    },
    "source": {
      "type": "string",
      "description": "题目来源（如：2024真题、模拟题等）",
      "default": ""
    },
    "year": {
      "type": ["integer", "null"],
      "description": "年份（真题年份）",
      "minimum": 2000,
      "maximum": 2030
    },
    "total_attempts": {
      "type": "integer",
      "description": "总答题次数",
      "default": 0,
      "minimum": 0
    },
    "correct_attempts": {
      "type": "integer",
      "description": "正确答题次数",
      "default": 0,
      "minimum": 0
    },
    "is_active": {
      "type": "boolean",
      "description": "是否启用",
      "default": true
    },
    "created_at": {
      "type": "integer",
      "description": "创建时间戳"
    },
    "updated_at": {
      "type": "integer",
      "description": "更新时间戳"
    }
  },
  "indexes": [
    { "key": { "category": 1, "sub_category": 1 }, "name": "idx_category" },
    { "key": { "difficulty": 1 }, "name": "idx_difficulty" },
    { "key": { "type": 1 }, "name": "idx_type" },
    { "key": { "knowledge_points": 1 }, "name": "idx_knowledge_points" },
    { "key": { "is_active": 1, "category": 1 }, "name": "idx_active_category" },
    { "key": { "created_at": -1 }, "name": "idx_created_at" }
  ],
  "examples": [
    {
      "_id": "q_001",
      "question": "马克思主义哲学的直接理论来源是？",
      "options": ["A. 德国古典哲学", "B. 英国古典政治经济学", "C. 法国空想社会主义", "D. 古希腊哲学"],
      "answer": "A",
      "analysis": "马克思主义哲学的直接理论来源是德国古典哲学，特别是黑格尔的辩证法和费尔巴哈的唯物主义。",
      "category": "政治",
      "sub_category": "马原",
      "type": "单选",
      "difficulty": "medium",
      "knowledge_points": ["马克思主义", "德国古典哲学"],
      "source": "2023真题",
      "year": 2023,
      "total_attempts": 1500,
      "correct_attempts": 1200,
      "is_active": true,
      "created_at": 1737792000000,
      "updated_at": 1737792000000
    }
  ]
}
