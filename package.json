{
  "name": "exam-master",
  "version": "2.2.0",
  "description": "考研备考小程序 - AI助力，一战成硕",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "uni -p h5",
    "dev:mp-weixin": "uni -p mp-weixin",
    "dev:mp-qq": "uni -p mp-qq",
    "dev:h5": "uni -p h5",
    "build": "uni build -p h5",
    "build:app": "uni build -p app",
    "dev:app": "uni -p app",
    "build:mp-weixin": "uni build -p mp-weixin && node scripts/build/inject-mp-weixin-privacy.mjs",
    "audit:mp-main-usage": "npm run build:mp-weixin && node scripts/build/check-mp-main-package-usage.mjs",
    "audit:ui-quality": "node scripts/build/ui-quality-gate.js",
    "audit:deep-scan": "node scripts/build/deep-scan.js",
    "audit:secrets:tracked": "bash scripts/build/audit-tracked-secrets.sh",
    "audit:laf:function-sources": "node scripts/build/audit-laf-function-sources.mjs",
    "audit:subpkg-sync": "node scripts/build/check-subpkg-duplicates.mjs",
    "test:cloud:smoke": "node scripts/build/live-cloud-smoke.mjs",
    "build:mp-qq": "uni build -p mp-qq",
    "build:h5": "uni build -p h5 && node scripts/build/copy-cdn-to-h5.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ src/",
    "lint:fix": "eslint --cache --cache-location node_modules/.cache/eslint/ src/ --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css,json}\"",
    "deps:check": "npm outdated",
    "deps:audit": "npm audit --registry=https://registry.npmjs.org || true",
    "deps:audit:prod": "npm audit --omit=dev --registry=https://registry.npmjs.org || true",
    "release:patch": "npm version patch --no-git-tag-version && git add package.json && git commit -m \"chore: bump version patch\"",
    "release:minor": "npm version minor --no-git-tag-version && git add package.json && git commit -m \"chore: bump version minor\"",
    "release:major": "npm version major --no-git-tag-version && git add package.json && git commit -m \"chore: bump version major\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@dcloudio/uni-app-plus": "^3.0.0-alpha-5000220260306001",
    "@dcloudio/uni-app-vite": "^3.0.0-alpha-5000220260306001",
    "@dcloudio/uni-components": "^3.0.0-alpha-5000220260306001",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "canvas-confetti": "^1.9.4",
    "katex": "^0.16.38",
    "markdown-it": "^14.1.1",
    "pinia": "2.1.7",
    "ts-fsrs": "^5.3.1",
    "vue": "3.4.21",
    "wot-design-uni": "^1.14.0"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.4.1",
    "@csstools/postcss-color-mix-function": "^3.0.12",
    "@dcloudio/types": "^3.3.2",
    "@dcloudio/uni-app": "^3.0.0-alpha-5000220260306001",
    "@dcloudio/uni-cli-shared": "^3.0.0-alpha-5000220260306001",
    "@dcloudio/uni-h5": "^3.0.0-alpha-5000220260306001",
    "@dcloudio/uni-mp-weixin": "^3.0.0-alpha-5000220260306001",
    "@dcloudio/vite-plugin-uni": "^3.0.0-alpha-5000220260306001",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "commitlint": "^20.4.1",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "happy-dom": "^20.5.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "miniprogram-automator": "^0.12.1",
    "prettier": "^3.5.3",
    "sass": "^1.97.3",
    "terser": "^5.27.0",
    "vite": "^5.2.8",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "yaml": "^2.8.3"
  },
  "keywords": [
    "uni-app",
    "vue3",
    "微信小程序",
    "考研",
    "AI学习"
  ],
  "author": "Exam-Master Team",
  "license": "MIT",
  "packageManager": "npm@10.8.2",
  "browserslist": [
    "Android >= 5",
    "iOS >= 10",
    "Chrome >= 53",
    "Safari >= 10",
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.8.2"
  }
}
