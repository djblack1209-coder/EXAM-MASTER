{
  "name": "exam-master",
  "version": "1.0.0",
  "description": "考研备考小程序 - AI助力，一战成硕",
  "main": "main.js",
  "scripts": {
    "dev": "uni",
    "dev:mp-weixin": "uni -p mp-weixin",
    "dev:mp-qq": "uni -p mp-qq",
    "dev:h5": "uni",
    "build": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin",
    "build:mp-qq": "uni build -p mp-qq",
    "build:h5": "uni build -p h5",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test --config=playwright.visual.config.js",
    "test:visual:update": "playwright test --config=playwright.visual.config.js --update-snapshots",
    "test:visual:ui": "playwright test --config=playwright.visual.config.js --ui",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ src/",
    "lint:fix": "eslint --cache --cache-location node_modules/.cache/eslint/ src/ --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@dcloudio/uni-components": "^3.0.0-alpha-3000020210521001",
    "pinia": "2.1.7",
    "vue": "3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.3.2",
    "@dcloudio/uni-app": "^3.0.0-alpha-5000020260104004",
    "@dcloudio/uni-cli-shared": "^3.0.0-alpha-5000020260104004",
    "@dcloudio/uni-mp-weixin": "^3.0.0-alpha-5000020260104004",
    "@dcloudio/vite-plugin-uni": "^3.0.0-alpha-5000020260104004",
    "@playwright/test": "^1.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "happy-dom": "^20.5.0",
    "husky": "^9.1.7",
    "sass": "^1.97.3",
    "terser": "^5.27.0",
    "vite": "^5.2.8",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "uni-app",
    "vue3",
    "微信小程序",
    "考研",
    "AI学习"
  ],
  "author": "Exam-Master Team",
  "license": "MIT",
  "browserslist": [
    "Android >= 5",
    "iOS >= 10",
    "Chrome >= 53",
    "Safari >= 10",
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
