{
	"bsonType": "object",
	"description": "错题本数据表",
	"required": ["user_id", "question_content", "correct_answer"],
	"properties": {
		"_id": {
			"description": "存储文档 ID（数据库自动生成）"
		},
		"user_id": {
			"bsonType": "string",
			"description": "用户ID",
			"label": "用户ID",
			"forceDefaultValue": {
				"$env": "uid"
			}
		},
		"question_content": {
			"bsonType": "string",
			"description": "题目内容",
			"label": "题目内容",
			"maxLength": 2000
		},
		"options": {
			"bsonType": "array",
			"description": "选项列表",
			"label": "选项",
			"items": {
				"bsonType": "string"
			}
		},
		"user_answer": {
			"bsonType": "string",
			"description": "用户答案",
			"label": "用户答案",
			"maxLength": 10
		},
		"correct_answer": {
			"bsonType": "string",
			"description": "正确答案",
			"label": "正确答案",
			"maxLength": 10
		},
		"analysis": {
			"bsonType": "string",
			"description": "AI解析",
			"label": "AI解析",
			"maxLength": 5000
		},
		"tags": {
			"bsonType": "array",
			"description": "标签列表（如科目、题型）",
			"label": "标签",
			"items": {
				"bsonType": "string"
			}
		},
		"created_at": {
			"bsonType": "timestamp",
			"description": "创建时间",
			"label": "创建时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"is_mastered": {
			"bsonType": "bool",
			"description": "是否已掌握",
			"label": "是否已掌握",
			"default": false
		},
		"wrong_count": {
			"bsonType": "int",
			"description": "错误次数",
			"label": "错误次数",
			"default": 1,
			"minimum": 0
		},
		"last_practice_time": {
			"bsonType": "timestamp",
			"description": "最后练习时间",
			"label": "最后练习时间"
		}
	},
	"permission": {
		"read": "doc.user_id == auth.uid",
		"create": "auth.uid != null",
		"update": "doc.user_id == auth.uid",
		"delete": "doc.user_id == auth.uid"
	},
	"indexes": [
		{
			"IndexName": "user_id_created_at",
			"MongodIndexOptions": {
				"Unique": false
			},
			"Keys": [
				{
					"Name": "user_id",
					"Direction": "1"
				},
				{
					"Name": "created_at",
					"Direction": "-1"
				}
			]
		},
		{
			"IndexName": "user_id_is_mastered",
			"MongodIndexOptions": {
				"Unique": false
			},
			"Keys": [
				{
					"Name": "user_id",
					"Direction": "1"
				},
				{
					"Name": "is_mastered",
					"Direction": "1"
				}
			]
		}
	]
}
