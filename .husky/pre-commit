# 执行 ESLint 检查暂存的文件
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|vue|ts)$' || true)

if [ -n "$STAGED_FILES" ]; then
  echo "Running ESLint on staged files..."
  npx eslint --cache --no-error-on-unmatched-pattern $STAGED_FILES
  if [ $? -ne 0 ]; then
    echo "ESLint check failed. Please fix the errors before committing."
    exit 1
  fi
fi

echo "Pre-commit check passed"
