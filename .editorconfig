# EditorConfig - 统一编辑器代码风格
# https://editorconfig.org

root = true

# 所有文件默认配置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Vue / JS / TS 文件
[*.{vue,js,ts,jsx,tsx}]
indent_style = space
indent_size = 2
quote_type = single

# SCSS / CSS 文件
[*.{scss,css}]
indent_style = space
indent_size = 2

# JSON 文件
[*.json]
indent_style = space
indent_size = 2

# Markdown 文件（保留行尾空格用于换行）
[*.md]
trim_trailing_whitespace = false

# YAML 文件
[*.{yml,yaml}]
indent_style = space
indent_size = 2
