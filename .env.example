# 🔐 Exam-Master 环境变量配置模板
# 
# 📝 使用说明：
# 1. 复制此文件为 .env.local（开发环境）或 .env.production（生产环境）
# 2. 填写真实的配置值
# 3. 不要将包含真实密钥的 .env 文件提交到版本控制
#
# ⚠️ 安全提示：
# - .env.local 和 .env.production 已在 .gitignore 中排除
# - 生产环境建议使用 Sealos 环境变量而非 .env 文件
# - API Key 应配置在后端，前端不应持有敏感密钥

# ==================== 微信小程序配置 ====================

# 微信小程序 AppID（必填）
# 获取方式：微信公众平台 -> 开发 -> 开发设置 -> AppID
# 当前硬编码位置：src/common/config.js:52
VITE_WX_APP_ID=wx5bee888cf32215df

# 微信小程序 AppSecret（仅后端使用，前端不需要）
# ⚠️ 警告：前端严禁配置 AppSecret！
# 后端配置位置：Sealos 环境变量 WX_APP_SECRET
# SECRET_PLACEHOLDER

# ==================== 后端服务配置 ====================

# Sealos 后端 API 地址（必填）
# 当前硬编码位置：src/services/lafService.js:5
# 开发环境示例：https://dev-api.exam-master.com
# 生产环境示例：https://api.exam-master.com
VITE_API_BASE_URL=https://nf98ia8qnt.sealosbja.site

# API 请求超时时间（毫秒）
VITE_API_TIMEOUT=30000

# ==================== AI 服务配置 ====================

# 智谱AI API密钥（可选，建议后端配置）
# ⚠️ 注意：当前架构使用后端代理模式，前端不需要此密钥
# 如需前端直接调用（不推荐），请取消注释并填写
# VITE_AI_PROVIDER_KEY_PLACEHOLDER

# 智谱AI 模型名称
VITE_AI_MODEL=glm-4-plus

# AI 请求超时时间（毫秒）
VITE_AI_TIMEOUT=60000

# ==================== 应用配置 ====================

# 应用名称
VITE_APP_NAME=Exam-Master

# 应用版本
VITE_APP_VERSION=1.0.0

# 分页大小
VITE_PAGE_SIZE=20

# ==================== 开发调试配置 ====================

# 是否启用调试模式（开发环境建议 true，生产环境必须 false）
VITE_DEBUG_MODE=false

# 是否启用 Mock 数据（开发环境可选）
VITE_ENABLE_MOCK=false

# ==================== 构建配置 ====================

# 是否在生产环境移除 console.log（建议 true）
# 注意：已在 vite.config.js 中配置，此处仅作记录
# VITE_DROP_CONSOLE=true

# ==================== 迁移说明 ====================

# 📌 待迁移的硬编码配置：
# 1. src/common/config.js:52 - WX_CONFIG.appId
#    → 替换为：import.meta.env.VITE_WX_APP_ID
#
# 2. src/services/lafService.js:5 - BASE_URL
#    → 替换为：import.meta.env.VITE_API_BASE_URL
#
# 3. src/common/config.js:15 - API_CONFIG.baseURL
#    → 替换为：import.meta.env.VITE_API_BASE_URL

# ==================== 环境变量使用示例 ====================

# 在代码中使用环境变量：
# const appId = import.meta.env.VITE_WX_APP_ID
# const apiUrl = import.meta.env.VITE_API_BASE_URL
# const isDebug = import.meta.env.VITE_DEBUG_MODE === 'true'

# ==================== 相关文档 ====================

# - Vite 环境变量文档：https://vitejs.dev/guide/env-and-mode.html
# - Sealos 环境变量配置：docs/development/phases/MODULE7_SEALOS_SETUP_GUIDE.md
# - 安全最佳实践：docs/security/API_KEY_SECURITY_FIX.md
