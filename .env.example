# 🔐 Exam-Master 环境变量配置模板
# 
# 📝 使用说明：
# 1. 复制此文件为 .env.local（开发环境）或 .env.production（生产环境）
# 2. 填写真实的配置值
# 3. 不要将包含真实密钥的 .env 文件提交到版本控制
#
# ⚠️ 安全提示：
# - .env.local 和 .env.production 已在 .gitignore 中排除
# - 生产环境建议使用 Sealos 环境变量而非 .env 文件
# - API Key 应配置在后端，前端不应持有敏感密钥

# ==================== 微信小程序配置 ====================

# 微信小程序 AppID（必填）
# 获取方式：微信公众平台 -> 开发 -> 开发设置 -> AppID
# 当前硬编码位置：src/common/config.js:52
VITE_WX_APP_ID=your_wx_app_id_here

# 微信小程序 AppSecret（仅后端使用，前端不需要）
# ⚠️ 警告：前端严禁配置 AppSecret！
# 后端配置位置：Sealos 环境变量 WX_APP_SECRET
# SECRET_PLACEHOLDER

# ==================== 微信公众号配置（H5微信浏览器登录） ====================

# 微信公众号 AppID（H5环境前端使用，用于 OAuth 网页授权跳转）
# 获取方式：微信公众平台 -> 设置与开发 -> 基本配置 -> AppID
# 注意：需要在公众号后台配置「网页授权域名」
VITE_WX_GZH_APP_ID=your_wx_gzh_app_id_here

# 微信公众号 AppSecret（仅后端使用，前端不需要）
# 后端配置位置：Sealos 环境变量 WX_GZH_SECRET
# SECRET_PLACEHOLDER

# ==================== QQ登录配置 ====================

# QQ互联 AppID（前端和后端都需要）
# 获取方式：QQ互联平台 (https://connect.qq.com) -> 应用管理 -> 创建应用
VITE_QQ_APP_ID=your_qq_app_id_here

# QQ OAuth 回调地址（H5环境需要）
# 格式：https://your-domain.com/#/pages/login/qq-callback (Hash模式)
# 或：https://your-domain.com/pages/login/qq-callback (History模式)
# 注意：此地址需要在QQ互联平台配置为授权回调域
# VITE_QQ_REDIRECT_URI=https://your-domain.com/#/pages/login/qq-callback

# QQ互联 AppKey（仅后端使用，前端严禁配置！）
# ⚠️ 警告：前端严禁配置 AppKey！
# 后端配置位置：Sealos 环境变量 QQ_SECRET
# SECRET_PLACEHOLDER

# 后端QQ回调地址（Sealos环境变量）
# QQ_REDIRECT_URI=https://your-sealos-domain.sealosbja.site/pages/login/qq-callback

# ==================== 邮箱服务配置 ====================

# SMTP 服务器配置（后端使用）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your_email@qq.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM=Exam-Master <noreply@exam-master.com>

# ==================== 后端服务配置 ====================

# Sealos 后端 API 地址（必填）
# 当前硬编码位置：src/services/lafService.js:5
# 开发环境示例：https://dev-api.exam-master.com
# 生产环境示例：https://api.exam-master.com
VITE_API_BASE_URL=https://your-sealos-domain.sealosbja.site

# API 请求超时时间（毫秒）
VITE_API_TIMEOUT=30000

# ==================== AI 服务配置 ====================

# 智谱AI API密钥（可选，建议后端配置）
# ⚠️ 注意：当前架构使用后端代理模式，前端不需要此密钥
# 如需前端直接调用（不推荐），请取消注释并填写
# VITE_AI_PROVIDER_KEY_PLACEHOLDER

# 智谱AI 模型名称
VITE_AI_MODEL=glm-4-plus

# AI 请求超时时间（毫秒）
VITE_AI_TIMEOUT=60000

# ==================== 应用配置 ====================

# 应用名称
VITE_APP_NAME=Exam-Master

# 应用版本
VITE_APP_VERSION=1.0.0

# 分页大小
VITE_PAGE_SIZE=20

# ==================== 开发调试配置 ====================

# 是否启用调试模式（开发环境建议 true，生产环境必须 false）
VITE_DEBUG_MODE=false

# 是否启用 Mock 数据（开发环境可选）
VITE_ENABLE_MOCK=false

# ==================== 构建配置 ====================

# 是否在生产环境移除 console.log（建议 true）
# 注意：已在 vite.config.js 中配置，此处仅作记录
# VITE_DROP_CONSOLE=true

# ==================== 存储配置 ====================

# 本地存储前缀（避免与其他应用冲突）
VITE_STORAGE_PREFIX=exam_master_

# 缓存过期时间（秒）
VITE_CACHE_EXPIRE=86400

# ==================== 上传配置 ====================

# 头像上传最大大小（字节，默认2MB）
VITE_AVATAR_MAX_SIZE=2097152

# 文件上传最大大小（字节，默认10MB）
VITE_FILE_MAX_SIZE=10485760

# 允许的图片格式
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ==================== 功能开关 ====================

# 是否启用PK对战功能
VITE_ENABLE_PK=true

# 是否启用AI诊断功能
VITE_ENABLE_AI_DIAGNOSIS=true

# 是否启用离线模式
VITE_ENABLE_OFFLINE=true

# 是否启用数据同步
VITE_ENABLE_SYNC=true

# ==================== 监控配置 ====================

# Sentry DSN（错误监控，可选）
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# 是否启用性能监控
VITE_ENABLE_PERFORMANCE_MONITOR=false

# ==================== 第三方服务配置 ====================

# 统计分析（可选）
# VITE_ANALYTICS_ID=your_analytics_id

# CDN 地址（可选，用于静态资源加速）
# VITE_CDN_URL=https://cdn.exam-master.com

# ==================== 迁移说明 ====================

# ✅ 所有硬编码配置已完成迁移！
# 
# 已完成迁移的配置：
# ✅ 1. src/common/config.js:67 - WX_CONFIG.appId
#    → 已替换为：import.meta.env.VITE_WX_APP_ID
#
# ✅ 2. src/services/lafService.js:6 - BASE_URL
#    → 已替换为：import.meta.env.VITE_API_BASE_URL
#
# ✅ 3. src/common/config.js:37 - API_CONFIG.baseURL
#    → 已替换为：import.meta.env.VITE_API_BASE_URL
#
# ✅ 4. src/common/config.js:38 - API_CONFIG.timeout
#    → 已替换为：import.meta.env.VITE_API_TIMEOUT

# ==================== 环境变量使用示例 ====================

# 在代码中使用环境变量：
# const appId = import.meta.env.VITE_WX_APP_ID
# const apiUrl = import.meta.env.VITE_API_BASE_URL
# const isDebug = import.meta.env.VITE_DEBUG_MODE === 'true'

