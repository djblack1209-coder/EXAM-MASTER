# ============================================================
# 测试环境变量（CI / Vitest 自动加载）
# 仅包含占位值，不含真实密钥，可安全提交到版本控制
# 与 .env.example 保持同步 — 审计日期: 2026-03-29
# ============================================================

# ===== 微信/QQ 配置 =====
VITE_WX_APP_ID=wx_test_app_id
VITE_WX_GZH_APP_ID=wx_test_gzh_app_id
VITE_QQ_APP_ID=qq_test_app_id
VITE_QQ_REDIRECT_URI=https://test.example.com/#/pages/login/qq-callback

# ===== 后端服务 =====
VITE_API_BASE_URL=https://test.example.com
VITE_API_TIMEOUT=30000

# ===== AI 配置 =====
VITE_AI_MODEL=glm-4-plus
VITE_AI_TIMEOUT=60000

# ===== 应用配置 =====
VITE_APP_NAME=Exam-Master-Test
VITE_APP_VERSION=1.0.0-test
VITE_PAGE_SIZE=20
VITE_APP_SCHEME=exammaster://

# ===== 调试 =====
VITE_DEBUG_MODE=true
VITE_ENABLE_MOCK=false

# ===== 安全 =====
VITE_OBFUSCATION_KEY=test_obfuscation_key_for_ci
VITE_REQUEST_SIGN_SALT=test_sign_salt
SECRET_PLACEHOLDER

# ===== 存储 =====
VITE_STORAGE_PREFIX=exam_test_
VITE_CACHE_EXPIRE=86400
VITE_CACHE_DEFAULT_TTL=300000
VITE_CACHE_LONG_TTL=3600000
VITE_CACHE_MAX_SIZE=200

# ===== 上传 =====
VITE_AVATAR_MAX_SIZE=2097152
VITE_FILE_MAX_SIZE=10485760
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ===== 功能开关 =====
VITE_ENABLE_PK=true
VITE_ENABLE_AI_DIAGNOSIS=true
VITE_ENABLE_OFFLINE=false
VITE_ENABLE_SYNC=false
VITE_AUDIT_MODE=false
VITE_ENABLE_HEAVY_FEATURES=true

# ===== WebSocket =====
VITE_WS_DEV_URL=ws://localhost:3000/ws/ranking
VITE_WS_PROD_URL=wss://test.example.com/ws/ranking
VITE_WS_MAX_RECONNECT=3

# ===== 深度链接 =====
VITE_H5_BASE_URL=https://test.example.com

# ===== 网络/监控 =====
VITE_PING_URL=/static/images/logo.png
VITE_SENTRY_DSN=
VITE_ENABLE_PERFORMANCE_MONITOR=false

# ===== 第三方服务 =====
VITE_ANALYTICS_ID=
VITE_CDN_URL=
VITE_DICEBEAR_BASE_URL=https://api.dicebear.com/7.x
VITE_ICONS8_BASE_URL=https://img.icons8.com
VITE_QR_SERVER_BASE_URL=https://api.qrserver.com/v1
