# ============================================
# Exam-Master Docker 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================

# ==================== 版本控制 ====================
VERSION=1.0.0

# ==================== MongoDB 配置 ====================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your-secure-password-here
MONGODB_URI=mongodb://exam-master-app:your-mongodb-password-here@mongo:27017/exam-master

# ==================== Redis 配置 ====================
REDIS_URL=redis://redis:6379

# ==================== AI 服务配置 ====================
AI_PROVIDER_KEY_PLACEHOLDER

# ==================== 监控配置 ====================
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-password-here

# ==================== 告警配置 ====================
# 企业微信机器人 Webhook
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# 钉钉机器人 Webhook
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token

# 邮件告警配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alert@example.com
SMTP_PASSWORD=your-smtp-password
ALERT_EMAIL_TO=devops@example.com

# ==================== 其他配置 ====================
TZ=Asia/Shanghai
NODE_ENV=production
