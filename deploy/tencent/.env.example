# 腾讯云部署环境变量模板
# 完整变量说明请参考 laf-backend/.env.example
# ============================================
# 复制为 .env 并填入真实值
# ============================================

# ---------- MongoDB ----------
MONGO_ROOT_PASSWORD=CHANGE_ME_strong_root_password
MONGO_APP_PASSWORD=CHANGE_ME_strong_app_password

# ---------- 镜像版本 ----------
VERSION=latest

# ---------- JWT/Auth ----------
JWT_SECRET_PLACEHOLDER
PASSWORD_SALT=your_password_salt_here

# ---------- 微信小程序 ----------
WX_APPID=your_wx_appid_here
WX_SECRET_PLACEHOLDER

# ---------- QQ 登录 ----------
QQ_APPID=your_qq_appid_here
SECRET_PLACEHOLDER

# ---------- AI 服务 ----------
AI_PROVIDER_KEY_PLACEHOLDER

# ---------- 管理员 ----------
SECRET_PLACEHOLDER
SECRET_PLACEHOLDER

# ---------- 请求签名 ----------
REQUEST_SIGN_SALT=your_request_sign_salt_here

# ---------- 邮件服务（SMTP） ----------
SMTP_HOST=your_smtp_host_here
SMTP_PORT=465
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_pass_here
